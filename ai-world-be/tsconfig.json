{
  "version": "2.4.2",
  "compilerOptions": {
    "lib": ["es5", "es6"],
    "target": "es6",
    "module": "Node16",
    "moduleResolution": "node16",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "exclude": [
    "node_modules"
  ]
}
